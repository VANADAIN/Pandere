package pandere:messenger@0.1.0;

interface types {
    enum service {
        telegram,
    }

    record plugin-metadata {
        id: string,
        display-name: string,
        service: service,
        version: string,
    }

    record auth-status {
        is-authenticated: bool,
        account-label: option<string>,
        session-handle: option<string>,
    }

    record chat-summary {
        id: string,
        title: string,
        last-message-preview: option<string>,
        unread-count: u32,
        last-activity-unix-secs: option<u64>,
    }

    record message {
        id: string,
        chat-id: string,
        author-name: string,
        text: string,
        sent-at-unix-secs: u64,
        is-outgoing: bool,
    }

    record sync-cursor {
        position: string,
        updated-at-unix-secs: u64,
    }

    record sync-page {
        messages: list<message>,
        next-cursor: option<sync-cursor>,
    }

    record search-query {
        text: string,
        limit: u32,
    }

    record search-result {
        message: message,
        score: option<f32>,
    }

    record retention-hints {
        can-persist-locally: bool,
        suggested-message-ttl-secs: option<u64>,
        suggested-media-ttl-secs: option<u64>,
    }

    record kv-entry {
        key: string,
        value: string,
    }

    record secret-ref {
        handle: string,
    }

    record http-request {
        method: string,
        url: string,
        headers: list<kv-entry>,
        body: option<list<u8>>,
    }

    record http-response {
        status: u16,
        headers: list<kv-entry>,
        body: list<u8>,
    }

    variant plugin-error {
        invalid-input(string),
        auth-required,
        rate-limited(string),
        upstream-failure(string),
        unsupported(string),
    }
}

interface host {
    use types.{http-request, http-response, plugin-error, secret-ref};

    now-unix-secs: func() -> u64;
    log: func(level: string, message: string);
    load-session: func(key: string) -> option<string>;
    store-session: func(key: string, value: string);
    load-secret: func(handle: secret-ref) -> result<string, plugin-error>;
    store-secret: func(label: string, value: string) -> result<secret-ref, plugin-error>;
    send-http: func(request: http-request) -> result<http-response, plugin-error>;
}

interface plugin {
    use types.{auth-status, chat-summary, message, plugin-error, plugin-metadata, retention-hints, search-query, search-result, sync-cursor, sync-page};

    metadata: func() -> plugin-metadata;
    get-auth-status: func() -> result<auth-status, plugin-error>;
    bootstrap-auth: func() -> result<auth-status, plugin-error>;
    list-chats: func() -> result<list<chat-summary>, plugin-error>;
    fetch-messages: func(chat-id: string, cursor: option<sync-cursor>) -> result<sync-page, plugin-error>;
    sync-updates: func(cursor: option<sync-cursor>) -> result<sync-page, plugin-error>;
    search-messages: func(query: search-query, chat-id: option<string>) -> result<list<search-result>, plugin-error>;
    send-text: func(chat-id: string, text: string) -> result<message, plugin-error>;
    get-retention-hints: func() -> retention-hints;
}

world messenger-plugin {
    import host;
    export plugin;
}
